# Anthropic API Key — required for blog generation
ANTHROPIC_API_KEY=

# Model to use (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=

# Web dashboard port (optional, defaults to 3847)
DASHBOARD_PORT=

# Demo mode — set to true to use mock data instead of real API calls (no charges)
# Great for development and testing. Remove or set to false for production.
DEMO_MODE=
